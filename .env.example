# ============================================================================
# .env.example — Production-Ready Env Vars fuer Stealth-Runner (2026-05-11)
# ============================================================================
# Kopiere diese Datei nach .env und fülle die echten Werte ein!
#   cp .env.example .env
#   # edit .env mit echten Werten
#
# Wichtig: .env NIEMALS in git committen (steht in .gitignore)!
# ============================================================================

# ── CORE / INFRASTRUCTURE ──────────────────────────────────────────────────

# Verzeichnis für State/Checkpoints/Screenshots (erlaubt mkdir -p automatisch)
STATE_DIR=~/.stealth/state
CHECKPOINT_DIR=~/.stealth/checkpoints
SCREENSHOT_DIR=~/.stealth/screenshots
LOG_DIR=~/.stealth/logs

# ── CHROME / BROWSER ───────────────────────────────────────────────────────

# Path zum Chrome/Chromium Binary (muss installiert sein!)
#   Ubuntu/Debian: apt-get install chromium-browser → /usr/bin/chromium
#   macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_EXECUTABLE=/usr/bin/chromium

# Chrome DevTools Protocol Port (lokal für CDP-Verbindung)
CHROME_PORT=9999
CHROME_HOST=127.0.0.1

# Chrome User-Data-Dir (Profile mit Cookies, Extensions etc.)
# Falls leer: ~/Library/Application Support/Google Chrome/Default
CHROME_USER_DATA_DIR=~/.stealth/chrome_profile

# ── SURVEY EXECUTION ───────────────────────────────────────────────────────

# Hard-Limit pro Survey in Sekunden (default 120 = 2 Minuten)
SURVEY_BUDGET_MAX_SECONDS=120

# Captcha-Solve-Timeout (max Sekunden pro Captcha-Versuch)
CAPTCHA_SOLVE_TIMEOUT_S=60

# ── CAPTCHA SOLVER / 2CAPTCHA ─────────────────────────────────────────────

# 2Captcha API Key (für hCaptcha, reCAPTCHA, Turnstile Fallback)
# Ohne Key: Solver skipped mit reason="api_key_missing"
# https://2captcha.com → Account → Settings → API Key
TWOCAPTCHA_API_KEY=

# Optional: Capsolver API Key (Alternative zu 2Captcha)
CAPSOLVER_API_KEY=

# ── OBSERVABILITY / MONITORING ─────────────────────────────────────────────

# Enable Screenshots bei Node-Failures? (true/false)
ENABLE_SCREENSHOTS_ON_ERROR=true

# Log-Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── AUDIT / SECURITY ───────────────────────────────────────────────────────

# Encryption Key für Vault (Secrets-Storage)
# Falls leer: generiert auto-ephemeral-key (nicht persistent!)
# Fuer Production: `openssl rand -hex 32` → hier einfuegen
VAULT_ENCRYPTION_KEY=

# ── LEGACY / PROVIDER CREDENTIALS ──────────────────────────────────────────

# HeyPiggy Account (wenn lokal getestet wird)
# HEYPIGGY_USERNAME=<email@example.com>
# HEYPIGGY_PASSWORD=<password>

# Legacy: CPX (falls noch in Nutzung)
CPX_APP_ID=
CPX_EXT_USER_ID=
CPX_SECURE_HASH=
CPX_EMAIL=

# Optional: Google, NVIDIA (Legacy)
GOOGLE_EMAIL=
NVIDIA_API_KEY=
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# ============================================================================
# PRODUCTION-CHECKLISTE VOR DEPLOYMENT (Issue #81/#82/#83)
# ============================================================================
# 
# - [ ] Alle Paths (STATE_DIR, CHECKPOINT_DIR, etc.) sind writable
# - [ ] CHROME_EXECUTABLE existiert: `which chromium` oder `which google-chrome`
# - [ ] TWOCAPTCHA_API_KEY gesetzt (wenn Captchas erwartet)
# - [ ] VAULT_ENCRYPTION_KEY nicht leer (openssl rand -hex 32)
# - [ ] SURVEY_BUDGET_MAX_SECONDS entspricht Zielzeit (default 120s)
# - [ ] ENABLE_SCREENSHOTS_ON_ERROR=true (für Debugging)
# - [ ] .env-Datei selbst in .gitignore + nicht gecheckt
# - [ ] Core-Bootstrap läuft vor Survey-Start: await bootstrap_core()
# - [ ] Alle LangGraph-Nodes sind ge-wrappen: sync_node_with_core(...)
# - [ ] Tests bestanden: pytest tests/test_core_*.py -q
# - [ ] FastAPI /core/health + /core/analytics erreichbar
#
# Erst dann: Starten mit 100+ Surveys im Auto-Loop
#
# ============================================================================

