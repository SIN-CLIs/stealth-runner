# OpenCode Database
OPENCODE_DB_PATH=~/.local/share/opencode/opencode.db

# NVIDIA NIM API (aligns with Stealth Suite Nemotron stack)
NVIDIA_API_KEY=nvapi-...
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-nano-omni-30b-a3b-reasoning

# Polling Configuration
POLL_INTERVAL=10
POLL_BATCH_SIZE=50

# Output Configuration
OUTPUT_DIR=docs/opencode-sessions/
LOGBOOK_PATH=logbook.stealth.yaml
CHANGELOG_DIR=docs/changelog/

# Logging
LOG_LEVEL=INFO
STRUCTLOG_PROCESSORS=console
