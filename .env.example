# ============================================================================
# .env.example — Production-Ready Env Vars fuer Stealth-Runner
# ============================================================================
# Kopiere diese Datei nach .env und fülle die echten Werte ein!
#   cp .env.example .env
#   # edit .env mit echten Werten
#
# Wichtig: .env NIEMALS in git committen (steht in .gitignore)!
# ============================================================================
#
# POLICY (SR-260, 2026-05-17) — UNVERHANDELBAR
# ----------------------------------------------
#  1. KEINE bezahlten Captcha-Solver (2Captcha, Capsolver, AntiCaptcha, ...).
#     Captchas werden ausschliesslich durch eigene Solver in
#     stealth-captcha/ und freie OSS-Loesungen geloest. Siehe
#     docs/CAPTCHA_STRATEGY.md.
#  2. KEIN direkter LLM-Provider-Key (OpenAI, Anthropic, Google, ...).
#     Saemtliche LLM-Calls laufen ausschliesslich ueber den Vercel AI
#     Gateway (AI_GATEWAY_API_KEY). Das ist auditierbar, kostenkontrolliert,
#     und mit einem einzigen Key konfigurierbar.
# ============================================================================

# ── CORE / INFRASTRUCTURE ──────────────────────────────────────────────────

# Verzeichnis für State/Checkpoints/Screenshots (erlaubt mkdir -p automatisch)
STATE_DIR=~/.stealth/state
CHECKPOINT_DIR=~/.stealth/checkpoints
SCREENSHOT_DIR=~/.stealth/screenshots
LOG_DIR=~/.stealth/logs

# ── CHROME / BROWSER ───────────────────────────────────────────────────────

# Path zum Chrome/Chromium Binary (muss installiert sein!)
#   Ubuntu/Debian: apt-get install chromium-browser → /usr/bin/chromium
#   macOS: /Applications/Google Chrome.app/Contents/MacOS/Google Chrome
CHROME_EXECUTABLE=/usr/bin/chromium

# Chrome DevTools Protocol Port (lokal für CDP-Verbindung)
CHROME_PORT=9999
CHROME_HOST=127.0.0.1

# Chrome User-Data-Dir (Profile mit Cookies, Extensions etc.)
# Falls leer: ~/Library/Application Support/Google Chrome/Default
CHROME_USER_DATA_DIR=~/.stealth/chrome_profile

# ── SURVEY EXECUTION ───────────────────────────────────────────────────────

# Hard-Limit pro Survey in Sekunden (default 120 = 2 Minuten)
SURVEY_BUDGET_MAX_SECONDS=120

# ── CAPTCHA SOLVER (NUR EIGENE / OSS — KEINE BEZAHLDIENSTE!) ──────────────

# Hartes Timeout pro Solve-Versuch (Sekunden). 60s ist innerhalb des
# 120s Survey-Budgets noch leistbar. Siehe docs/CAPTCHA_STRATEGY.md fuer
# die Liste der unterstuetzten Captcha-Typen + OSS-Solver-Roadmap.
CAPTCHA_SOLVE_TIMEOUT_S=60

# ── LLM BACKEND — VERCEL AI GATEWAY (NUR DIES!) ───────────────────────────
#
# Saemtliche LLM-Calls (Trajectory-Judge, Vision-Fallback, Answer-Engine
# wenn aktiviert) gehen ueber diesen einen Endpoint. Die Gateway-API ist
# OpenAI-kompatibel — model-Strings sind 'provider/model', z.B.
# 'openai/gpt-4o-mini' oder 'anthropic/claude-3-5-sonnet'.

# Vercel AI Gateway API Key
# https://vercel.com/<team>/~/ai/gateway → API Keys
AI_GATEWAY_API_KEY=

# Optional: Gateway Base URL Override (Default: https://gateway.ai.vercel.com/v1)
AI_GATEWAY_BASE_URL=

# ── OBSERVABILITY / MONITORING ─────────────────────────────────────────────

# Enable Screenshots bei Node-Failures? (true/false)
ENABLE_SCREENSHOTS_ON_ERROR=true

# Log-Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO

# ── AUDIT / SECURITY ───────────────────────────────────────────────────────

# Encryption Key für Vault (Secrets-Storage)
# Falls leer: generiert auto-ephemeral-key (nicht persistent!)
# Fuer Production: `openssl rand -hex 32` → hier einfuegen
VAULT_ENCRYPTION_KEY=

# ── LEGACY / PROVIDER CREDENTIALS ──────────────────────────────────────────

# HeyPiggy Account (wenn lokal getestet wird)
# HEYPIGGY_USERNAME=<email@example.com>
# HEYPIGGY_PASSWORD=<password>

# Legacy: CPX (falls noch in Nutzung)
CPX_APP_ID=
CPX_EXT_USER_ID=
CPX_SECURE_HASH=
CPX_EMAIL=

# Legacy / Optional: Google
GOOGLE_EMAIL=

# ── PERFORMANCE / CACHE (SR-243) ──────────────────────────────────────────

# Action-Recipe-Cache: speichert erfolgreiche page→action Entscheidungen
# und replayed sie beim nächsten Besuch derselben Seite OHNE LLM-Call.
# Default: "1" (ON). Setze auf "0" um den Cache komplett zu deaktivieren.
# Empfehlung: IMMER "1" in Production — spart 5-10x Latenz auf Repeat-Surveys.
STEALTH_RECIPE_CACHE=1

# DLQ-Replay Rate-Limit (SR-251): max Replays pro Minute bei DLQ-Sweep.
# Default: 5 replays/min mit Burst-5. Erhöhen nur wenn Provider-Throughput
# nachweislich höher ist.
DLQ_REPLAY_RATE=5
DLQ_REPLAY_BURST=5
