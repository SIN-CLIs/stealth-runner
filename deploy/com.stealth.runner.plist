<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0"><dict>
    <key>Label</key><string>com.stealth.runner</string>
    <key>ProgramArguments</key><array><string>/usr/local/bin/stealth-runner</string><string>run</string><string>https://heypiggy.com/?page=dashboard</string></array>
    <key>RunAtLoad</key><true/><key>KeepAlive</key><true/>
    <key>ThrottleInterval</key><integer>300</integer>
    <key>StandardOutPath</key><string>/tmp/stealth-daemon.log</string>
    <key>StandardErrorPath</key><string>/tmp/stealth-daemon.err</string>
</dict></plist>
