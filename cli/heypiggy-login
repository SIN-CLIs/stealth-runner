#!/bin/bash
# heypiggy-login — Google OAuth Login auf heypiggy.com
# KORREKT (2026-05-02): skylight-cli nur für Hauptseite, cua-driver für Popups!
# Nutzung: bash cli/heypiggy-login <PID>
set -euo pipefail
PID="${1:-}"
PROFILE_FILE="profiles/jeremy.yaml"

if [ -z "$PID" ]; then
    echo '{"status":"error","reason":"no_pid"}'
    exit 1
fi

EMAIL=$(python3 -c "import yaml; print(yaml.safe_load(open('$PROFILE_FILE'))['google_email'])" 2>/dev/null || echo "")
PW=$(python3 -c "import yaml; print(yaml.safe_load(open('$PROFILE_FILE'))['google_password'])" 2>/dev/null || echo "")

if [ -z "$EMAIL" ]; then
    echo '{"status":"error","reason":"no_email"}'
    exit 1
fi

skylight() { /Users/jeremy/.local/bin/skylight-cli "$@"; }
cua()      { cua-driver call "$@"; }

echo "{\"status\":\"login_start\",\"pid\":$PID}" >&2

# ── PHASE 1: Google Button auf HAUPTSEITE klicken (skylight-cli) ──
echo '{"step":1,"phase":"main_page","tool":"skylight-cli","action":"click_google_button"}' >&2
GOOGLE=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if 'google login' in (e.get('label','')or'').lower() and e['role']=='AXLink':
        print(e['index']); break
")
if [ -z "$GOOGLE" ]; then
    echo '{"status":"error","reason":"no_google_button_on_main_page"}'
    exit 2
fi
skylight click --pid "$PID" --element-index "$GOOGLE" >/dev/null
echo "{\"step\":1,\"done\":true,\"element_index\":$GOOGLE}" >&2
sleep 5

# ── PHASE 2: Popup via cua-driver (daemon starten) ──
echo '{"step":2,"phase":"popup","tool":"cua-driver","action":"start_daemon"}' >&2
cua-driver serve &
sleep 3

# ── PHASE 3: Popup finden ──
echo '{"step":3,"phase":"popup","tool":"cua-driver","action":"find_popup"}' >&2
POPUP=$(cua list_windows '{}' 2>/dev/null | python3 -c "
import sys,json
d=json.load(sys.stdin)
for w in d.get('windows',[]):
    if w.get('pid')==$PID and w.get('is_on_screen') and 'anmelden' in w.get('title','').lower() and w['bounds'].get('width',0)>300:
        print(w['window_id']); break
")
if [ -z "$POPUP" ]; then
    echo '{"status":"error","reason":"no_google_popup_found"}'
    exit 3
fi
echo "{\"step\":3,\"done\":true,\"window_id\":$POPUP}" >&2

# ── PHASE 4: Email im Popup eintippen (cua-driver set_value) ──
echo '{"step":4,"phase":"popup","tool":"cua-driver","action":"type_email"}' >&2
cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" >/dev/null 2>&1  # cache elements
EMAIL_FIELD=$(cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" 2>/dev/null | python3 -c "
import sys,json,re
d=json.load(sys.stdin)
tree=d.get('tree_markdown','')
for m in re.finditer(r'\[(\d+)\]\s+AXTextField\s+\"([^\"]*E-Mail[^\"]*)\"', tree):
    print(m.group(1)); break
")
if [ -n "$EMAIL_FIELD" ]; then
    cua set_value "{\"pid\":$PID,\"window_id\":$POPUP,\"element_index\":$EMAIL_FIELD,\"value\":\"$EMAIL\"}" >/dev/null 2>&1
    echo "{\"step\":4,\"done\":true,\"element_index\":$EMAIL_FIELD}" >&2
    sleep 2
else
    echo "{\"step\":4,\"note\":\"email_prefilled_or_not_needed\"}" >&2
fi

# ── PHASE 5: "Weiter" im Popup klicken ──
echo '{"step":5,"phase":"popup","tool":"cua-driver","action":"click_weiter"}' >&2
cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" >/dev/null 2>&1
WEITER_IDX=$(cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" 2>/dev/null | python3 -c "
import sys,json,re
d=json.load(sys.stdin)
tree=d.get('tree_markdown','')
for m in re.finditer(r'\[(\d+)\]\s+AXButton\s+\"Weiter\"', tree):
    print(m.group(1)); break
")
if [ -n "$WEITER_IDX" ]; then
    cua click "{\"pid\":$PID,\"window_id\":$POPUP,\"element_index\":$WEITER_IDX,\"action\":\"press\"}" >/dev/null 2>&1
    echo "{\"step\":5,\"done\":true,\"element_index\":$WEITER_IDX}" >&2
    sleep 5
fi

# ── PHASE 6: Consent "Fortfahren" (falls vorhanden) ──
echo '{"step":6,"phase":"popup","tool":"cua-driver","action":"click_fortfahren"}' >&2
cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" >/dev/null 2>&1
FORTFAHREN=$(cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" 2>/dev/null | python3 -c "
import sys,json,re
d=json.load(sys.stdin)
tree=d.get('tree_markdown','')
for m in re.finditer(r'\[(\d+)\]\s+AXButton\s+\"Fortfahren\"', tree):
    print(m.group(1)); break
")
if [ -n "$FORTFAHREN" ]; then
    cua click "{\"pid\":$PID,\"window_id\":$POPUP,\"element_index\":$FORTFAHREN,\"action\":\"press\"}" >/dev/null 2>&1
    echo "{\"step\":6,\"done\":true,\"element_index\":$FORTFAHREN}" >&2
    sleep 5
fi

# ── PHASE 7: Finaler "Weiter" nach Consent ──
echo '{"step":7,"phase":"popup","tool":"cua-driver","action":"click_final_weiter"}' >&2
cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" >/dev/null 2>&1
FINAL_WEITER=$(cua get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" 2>/dev/null | python3 -c "
import sys,json,re
d=json.load(sys.stdin)
tree=d.get('tree_markdown','')
for m in re.finditer(r'\[(\d+)\]\s+AXButton\s+\"Weiter\"', tree):
    print(m.group(1)); break
")
if [ -n "$FINAL_WEITER" ]; then
    cua click "{\"pid\":$PID,\"window_id\":$POPUP,\"element_index\":$FINAL_WEITER,\"action\":\"press\"}" >/dev/null 2>&1
    echo "{\"step\":7,\"done\":true,\"element_index\":$FINAL_WEITER}" >&2
    sleep 5
fi

# ── VERIFIKATION: Popup weg? ──
echo '{"step":8,"phase":"verify","tool":"cua-driver","action":"check_popup_closed"}' >&2
for i in 1 2 3; do
    sleep 3
    POPUP_CHECK=$(cua list_windows '{}' 2>/dev/null | python3 -c "
import sys,json
d=json.load(sys.stdin)
for w in d.get('windows',[]):
    if w.get('pid')==$PID and w.get('is_on_screen') and 'anmelden' in w.get('title','').lower():
        print(w['window_id']); break
")
    if [ -z "$POPUP_CHECK" ]; then
        echo "{\"step\":8,\"popup_gone\":true,\"attempt\":$i}" >&2
        echo "{\"status\":\"ok\",\"verified_by\":\"popup_gone\",\"pid\":$PID,\"email\":\"$EMAIL\"}"
        exit 0
    fi
    echo "{\"step\":8,\"popup_still_open\":$POPUP_CHECK,\"attempt\":$i}" >&2
done

echo "{\"status\":\"error\",\"reason\":\"popup_still_open_after_retries\",\"pid\":$PID}"
exit 10
