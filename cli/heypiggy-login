#!/bin/bash
# heypiggy-login — Google OAuth Login auf heypiggy.com
# NUR skylight-cli, KEIN osascript, KEIN webauto-nodriver
# Nutzung: bash cli/heypiggy-login <PID>
set -euo pipefail
PID="${1:-}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
PROFILE_FILE="$PROJECT_DIR/profiles/jeremy.yaml"

if [ -z "$PID" ]; then
    echo '{"status":"error","reason":"no_pid — usage: heypiggy-login <PID>"}'
    exit 1
fi

EMAIL=$(python3 -c "import yaml; print(yaml.safe_load(open('$PROFILE_FILE'))['google_email'])" 2>/dev/null || echo "${GOOGLE_EMAIL:-}")
PW=$(python3 -c "import yaml; print(yaml.safe_load(open('$PROFILE_FILE'))['google_password'])" 2>/dev/null || echo "${GOOGLE_PASSWORD:-}")

if [ -z "$EMAIL" ]; then
    echo '{"status":"error","reason":"no_email — set GOOGLE_EMAIL or create profiles/jeremy.yaml"}'
    exit 1
fi

echo "{\"status\":\"logging_in\",\"pid\":$PID,\"email\":\"$EMAIL\"}" >&2

skylight() { /Users/jeremy/.local/bin/skylight-cli "$@" 2>/dev/null; }

# Schritt 1: Google Login Button finden und klicken
echo '{"step":1,"action":"find_google_button"}' >&2
GOOGLE=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if 'google' in (e.get('label','')or'').lower() and e['role']=='AXLink':
        print(e['index']); break
")
if [ -z "$GOOGLE" ]; then
    echo '{"status":"error","reason":"no_google_button","step":1}'
    exit 2
fi
skylight click --pid "$PID" --element-index "$GOOGLE"
sleep 5

# Schritt 2: Email-Feld finden und Email eingeben
echo '{"step":2,"action":"type_email"}' >&2
EMAIL_FIELD=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role']=='AXTextField' and ('telefon' in (e.get('label','')or'').lower() or 'e-mail' in (e.get('label','')or'').lower()):
        print(e['index']); break
")
if [ -z "$EMAIL_FIELD" ]; then
    echo '{"status":"error","reason":"no_email_field","step":2}'
    exit 3
fi
skylight type --pid "$PID" --element-index "$EMAIL_FIELD" --text "$EMAIL"
sleep 3

# Schritt 3: Weiter klicken
echo '{"step":3,"action":"click_weiter"}' >&2
WEITER=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role']=='AXButton' and 'weiter' in (e.get('label','')or'').lower():
        print(e['index']); break
")
if [ -n "$WEITER" ]; then
    skylight click --pid "$PID" --element-index "$WEITER"
    sleep 5
fi

# Schritt 4: Passwort-Feld (Google auto-advance)
echo '{"step":4,"action":"type_password"}' >&2
PW_FIELD=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    label = (e.get('label','')or'').lower()
    if e['role']=='AXTextField' and any(k in label for k in ['passwort','password','verschlüsselt']):
        print(e['index']); break
")
if [ -n "$PW_FIELD" ] && [ -n "$PW" ]; then
    skylight type --pid "$PID" --element-index "$PW_FIELD" --text "$PW"
    sleep 1
    PW_WEITER=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role']=='AXButton' and 'weiter' in (e.get('label','')or'').lower():
        print(e['index']); break
")
    if [ -n "$PW_WEITER" ]; then
        skylight click --pid "$PID" --element-index "$PW_WEITER"
        sleep 5
    fi
fi

echo "{\"status\":\"ok\",\"pid\":$PID,\"email\":\"$EMAIL\"}"
