#!/bin/bash
# heypiggy-login — Google OAuth Login auf heypiggy.com
# NUR skylight-cli, KEIN osascript, KEIN webauto-nodriver
# Nutzung: bash cli/heypiggy-login <PID>
set -euo pipefail
PID="${1:-}"
SCRIPT_DIR="$(cd "$(dirname "$0")" && pwd)"
PROJECT_DIR="$(dirname "$SCRIPT_DIR")"
PROFILE_FILE="$PROJECT_DIR/profiles/jeremy.yaml"

if [ -z "$PID" ]; then
    echo '{"status":"error","reason":"no_pid — usage: heypiggy-login <PID>"}'
    exit 1
fi

EMAIL=$(python3 -c "import yaml; print(yaml.safe_load(open('$PROFILE_FILE'))['google_email'])" 2>/dev/null || echo "${GOOGLE_EMAIL:-}")
PW=$(python3 -c "import yaml; print(yaml.safe_load(open('$PROFILE_FILE'))['google_password'])" 2>/dev/null || echo "${GOOGLE_PASSWORD:-}")

if [ -z "$EMAIL" ]; then
    echo '{"status":"error","reason":"no_email — set GOOGLE_EMAIL or create profiles/jeremy.yaml"}'
    exit 1
fi

echo "{\"status\":\"logging_in\",\"pid\":$PID,\"email\":\"$EMAIL\"}" >&2

skylight() { /Users/jeremy/.local/bin/skylight-cli "$@" 2>/dev/null; }

# Schritt 1: Google Login Button finden und klicken
echo '{"step":1,"action":"find_google_button"}' >&2
GOOGLE=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if 'google' in (e.get('label','')or'').lower() and e['role']=='AXLink':
        print(e['index']); break
")
if [ -z "$GOOGLE" ]; then
    echo '{"status":"error","reason":"no_google_button","step":1}'
    exit 2
fi
skylight click --pid "$PID" --element-index "$GOOGLE"
sleep 5

# Schritt 2: Email-Feld finden und Email eingeben
echo '{"step":2,"action":"type_email"}' >&2
EMAIL_FIELD=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role']=='AXTextField' and ('telefon' in (e.get('label','')or'').lower() or 'e-mail' in (e.get('label','')or'').lower()):
        print(e['index']); break
")
if [ -z "$EMAIL_FIELD" ]; then
    echo '{"status":"error","reason":"no_email_field","step":2}'
    exit 3
fi
skylight type --pid "$PID" --element-index "$EMAIL_FIELD" --text "$EMAIL"
sleep 3

# Schritt 3: Weiter klicken
echo '{"step":3,"action":"click_weiter"}' >&2
WEITER=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role']=='AXButton' and 'weiter' in (e.get('label','')or'').lower():
        print(e['index']); break
")
if [ -n "$WEITER" ]; then
    skylight click --pid "$PID" --element-index "$WEITER"
    sleep 5
fi

# Schritt 4: Passwort-Feld (Google auto-advance)
echo '{"step":4,"action":"type_password"}' >&2
PW_FIELD=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    label = (e.get('label','')or'').lower()
    if e['role']=='AXTextField' and any(k in label for k in ['passwort','password','verschlüsselt']):
        print(e['index']); break
")
if [ -n "$PW_FIELD" ] && [ -n "$PW" ]; then
    skylight type --pid "$PID" --element-index "$PW_FIELD" --text "$PW"
    sleep 1
    PW_WEITER=$(skylight list-elements --pid "$PID" | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if e['role']=='AXButton' and 'weiter' in (e.get('label','')or'').lower():
        print(e['index']); break
")
    if [ -n "$PW_WEITER" ]; then
        skylight click --pid "$PID" --element-index "$PW_WEITER"
        sleep 5
    fi
fi

# Verifikation: Ist das Google-Popup weg?
echo '{"step":5,"action":"verify_popup_closed"}' >&2
for i in 1 2 3; do
    sleep 3
    # cua-driver list_windows → Popup noch offen?
    POPUP=$(cua-driver call list_windows 2>/dev/null | python3 -c "
import json,sys
for w in json.load(sys.stdin).get('windows',[]):
    if w.get('pid') == $PID and 'anmelden' in w.get('title','').lower() and w.get('is_on_screen',False):
        print(w['window_id']); break
" 2>/dev/null)
    if [ -z "$POPUP" ]; then
        # Popup weg – ABER: ohne Omni-Vision sind wir blind
        echo "{\"status\":\"blind\",\"message\":\"popup_closed_but_unverified_by_vision\",\"pid\":$PID,\"email\":\"$EMAIL\"}"
        echo "{\"step\":6,\"action\":\"omni_verify_login\"}" >&2
        
        # Omni soll prüfen ob wir wirklich eingeloggt sind
        skylight screenshot --pid "$PID" --mode som --output /tmp/verify_login.png 2>/dev/null
        # Workaround: skylight schreibt ins CWD
        cp -f skylight_screenshot.png /tmp/verify_login.png 2>/dev/null || true
        
        OMIN_RESULT=$(python3 -c "
import httpx, base64, json, os, re
key = os.environ.get('NVIDIA_API_KEY','')
with open('/tmp/verify_login.png','rb') as f: b64 = base64.b64encode(f.read()).decode()
r = httpx.post('https://integrate.api.nvidia.com/v1/chat/completions',
    headers={'Authorization':f'Bearer {key}'},
    json={'model':'nvidia/nemotron-3-nano-omni-30b-a3b-reasoning',
          'messages':[{'role':'user','content':[
              {'type':'text','text':'Is the user logged into Heypiggy.com? Reply JSON: {\"logged_in\":true/false,\"page\":\"...\",\"reasoning\":\"...\"}'},
              {'type':'image_url','image_url':{'url':f'data:image/png;base64,{b64}'}}]}],
          'max_tokens':200,'temperature':0.1}, timeout=30)
m = r.json()['choices'][0]['message']
t = m.get('reasoning') or m.get('content') or '{}'
import re
m2 = re.search(r'\{.*\}', t, re.DOTALL)
d = json.loads(m2.group()) if m2 else {}
print(json.dumps(d))
" 2>/dev/null)
        
        LOGGED_IN=$(echo "$OMIN_RESULT" | python3 -c "import json,sys;d=json.load(sys.stdin);print(d.get('logged_in',False))" 2>/dev/null)
        if [ "$LOGGED_IN" = "True" ]; then
            echo "{\"status\":\"ok\",\"verified_by\":\"nemotron-omni\",\"pid\":$PID,\"email\":\"$EMAIL\"}"
            exit 0
        else
            echo "{\"status\":\"blind\",\"message\":\"popup_weg_aber_omni_sagt_nicht_eingeloggt\",\"omni\":$OMIN_RESULT,\"pid\":$PID}"
            exit 0
        fi
    fi
    echo "{\"step\":5.${i},\"action\":\"popup_noch_offen(WID=$POPUP)\"}" >&2
    # cua-driver daemon muss laufen fuer popup-click
    cua-driver serve 2>/dev/null &
    sleep 1
    # Popup-Elemente via cua-driver (NICHT skylight — die sehen anderes Fenster!)
    POPUP_WEITER=$(cua-driver call get_window_state "{\"pid\":$PID,\"window_id\":$POPUP}" 2>/dev/null | python3 -c "
import json,sys
tree = json.load(sys.stdin).get('tree_markdown','')
for line in tree.split(chr(10)):
    if 'Button' in line and 'Weiter' in line:
        import re; m = re.search(r'\[(\d+)\]', line)
        if m: print(m.group(1)); break
" 2>/dev/null)
    if [ -n "$POPUP_WEITER" ]; then
        echo "{\"step\":5.${i},\"action\":\"click_weiter_in_popup(WID=$POPUP,idx=$POPUP_WEITER,cua_driver)\"}" >&2
        cua-driver call click "{\"pid\":$PID,\"window_id\":$POPUP,\"element_index\":$POPUP_WEITER,\"action\":\"press\"}" 2>/dev/null | python3 -c "import json,sys;print(json.load(sys.stdin).get('status','error'))" >&2
    fi
done
# Nach 3 Versuchen: Login fehlgeschlagen
echo "{\"status\":\"error\",\"reason\":\"popup_still_open_after_3_attempts\",\"pid\":$PID,\"popup_window_id\":$POPUP}"
exit 10
