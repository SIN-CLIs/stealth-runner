#!/bin/bash
# Klickt auf "Umfrage starten" und prüft auf neuen Tab
set -euo pipefail
PID="${1:?PID erforderlich}"

BTN=$(skylight-cli list-elements --pid "$PID" 2>/dev/null | python3 -c "
import json,sys
for e in json.load(sys.stdin)['elements']:
    if 'Umfrage starten' in (e.get('label','')or''):
        print(e['index']); break
")
[ -z "$BTN" ] && echo '{"status":"error","reason":"no_survey_button"}' && exit 1

skylight-cli click --pid "$PID" --element-index "$BTN" 2>/dev/null >/dev/null
sleep 4

TITLE=$(skylight-cli get-window-state --pid "$PID" 2>/dev/null | python3 -c "import json,sys; print(json.load(sys.stdin).get('title',''))")
echo "{\"status\":\"started\",\"window_title\":\"$TITLE\"}"
