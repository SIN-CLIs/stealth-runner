#!/bin/bash
# heypiggy-logout — Abmelden von heypiggy.com
set -euo pipefail
PID=${1:-$(pgrep -f "Google Chrome.app/Contents/MacOS/Google Chrome$" | head -1)}

echo "{\"status\":\"logging_out\",\"method\":\"incognito\"}"
open -na "Google Chrome" --args --incognito "https://heypiggy.com/?page=dashboard"
sleep 4
echo "{\"status\":\"ok\"}"
