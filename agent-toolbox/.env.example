# Agent-Toolbox Configuration
# Copy to .env and fill in real values. Never commit .env!

# Browser Settings
BROWSER_HEADLESS=true
BROWSER_TIMEOUT=30000
PROFILE_DIR=./profiles

# Chrome Binary (macOS default)
CHROME_BINARY=/Applications/Google Chrome.app/Contents/MacOS/Google Chrome

# Survey Settings
CPX_APP_ID=your_app_id
CPX_EXT_USER_ID=your_user_id
CPX_SECURE_HASH=your_secure_hash
CPX_EMAIL=your_email@example.com

# Google OAuth (for HeyPiggy login)
GOOGLE_EMAIL=your_google_email@gmail.com

# NVIDIA NIM (for survey decisions)
NVIDIA_API_KEY=nvapi-xxxxxxxxxxxxxxxxxxxxxxxx

# CDP Port
CDP_PORT=9999

# API Settings
API_HOST=0.0.0.0
API_PORT=8000
API_RELOAD=false
